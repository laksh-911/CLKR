//@version=5
strategy("Reverse Engineered Strategy: SPY", overlay=true, initial_capital=10000, default_qty_type=strategy.percent_of_equity, default_qty_value=100)

// Backtesting Window Parameters
holdingPeriod = input.int(15, title="Holding Period (bars)")
stopLossPct = input.float(5.0, title="Stop Loss %") / 100.0
takeProfitPct = input.float(15.0, title="Take Profit %") / 100.0

// Technical Indicator Declarations
ema_0 = ta.ema(close, 20)
rsi_1 = ta.rsi(close, 14)

// Buy Condition
buyCondition = ta.crossover(close, ema_0) and ta.crossover(rsi_1, 30)

// Trade State Machine (Position Tracker)
inPosition = strategy.position_size > 0

var int entryBar = na
var float entryPrice = na

if inPosition
    if na(entryBar)
        entryBar := bar_index
        entryPrice := strategy.position_avg_price
else
    entryBar := na
    entryPrice := na

if not inPosition
    if buyCondition
        strategy.entry("Buy", strategy.long)
else
    daysHeld = bar_index - entryBar
    priceChange = (close - entryPrice) / entryPrice
    
    stopTrigger = priceChange <= -stopLossPct
    tpTrigger = priceChange >= takeProfitPct
    holdTrigger = daysHeld >= holdingPeriod
    
    if stopTrigger or tpTrigger or holdTrigger
        strategy.close("Buy", comment = stopTrigger ? "Stop Loss" : tpTrigger ? "Take Profit" : "Holding Period")
